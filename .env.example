# Copy this file to `.env` and fill values.

# Database
POSTGRES_DB=prompt_cms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
BACKEND_DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/prompt_cms

# Common
PUSH_AUTH_TOKEN=local-dev-token
CMS_ENVIRONMENT=dev

# Agent YAML storage
PROMPT_YAML_DIR=/app/data/prompts

# LangSmith tracing options
LANGSMITH_TRACING=false
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=prompt-cms-agent
LANGSMITH_ENDPOINT=

# Frontend/Streamlit endpoints
FRONTEND_API_BASE_URL=http://localhost:8000
STREAMLIT_AGENT_BASE_URL=http://agent:8010
STREAMLIT_BACKEND_BASE_URL=http://backend:8000
